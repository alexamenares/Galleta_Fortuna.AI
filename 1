def limpiar_pantalla():
    os.system('cls' if os.name == 'nt' else 'clear')

def cargar():
    if os.path.exists(ARCHIVO):
        with open(ARCHIVO, "r", encoding="utf-8") as f:
            return json.load(f)
    return {"usuarios": {}}

def guardar_con_backup(data):
    # Backup antes de guardar
    if os.path.exists(ARCHIVO):
        backup_name = f"{ARCHIVO}.bak"
        try:
            import shutil
            shutil.copy(ARCHIVO, backup_name)
        except:
            pass  # Si falla el backup, no pasa nada
    
    with open(ARCHIVO, "w", encoding="utf-8") as f:
        json.dump(data, f, indent=2, ensure_ascii=False)

def pedir_nombre():
    while True:
        n = input("👤 tu nombre: ").strip()
        if n:
            return n
        print("necesitas un nombre. la galleta no trabaja con anónimos.")

def extraer_temas(texto):
    """Extrae palabras clave simples del texto"""
    palabras_clave = ["trabajo", "amor", "familia", "salud", "dinero", 
                      "miedo", "alegría", "tristeza", "sueño", "meta"]
    texto_lower = texto.lower()
    encontrados = [p for p in palabras_clave if p in texto_lower]
    return encontrados[:3]  # máximo 3 temas

def obtener_personalidad(usuario):
    rompimientos = usuario.get("rompimientos", 0)
    
    if rompimientos > 15:
        return "agotada"
    elif rompimientos > 8:
        return "sarcastica"
    elif rompimientos > 3:
        return "sabia"
    elif rompimientos > 0:
        return "neutral"
    else:
        return "curiosa"

def obtener_frase(usuario):
    personalidad = obtener_personalidad(usuario)
    rompimientos = usuario.get("rompimientos", 0)
    
    # Si está agotada, solo frases mínimas
    if personalidad == "agotada":
        return random.choice(PERSONALIDADES["agotada"]["frases"]), personalidad
    
    frases = PERSONALIDADES.get(personalidad, PERSONALIDADES["neutral"])["frases"]
    
    # Evitar repetir la misma frase seguida
    ultima = usuario.get("ultima_frase", "")
    if len(frases) > 1:
        frase = random.choice(frases)
        while frase == ultima:
            frase = random.choice(frases)
    else:
        frase = frases[0]
    
    usuario["ultima_frase"] = frase
    return frase, personalidad

def desbloquear_logros(usuario):
    nuevos = []
    rompimientos = usuario.get('rompimientos', 0)
    historial = usuario.get('historial', [])
    recuerdos = len(usuario.get('recuerdos', []))
    
    # Contar personalidades
    sabias = sum(1 for h in historial if h.get('personalidad') == 'sabia')
    sarcasticas = sum(1 for h in historial if h.get('personalidad') == 'sarcastica')
    
    # Días únicos
    fechas_unicas = len(set(h.get('fecha', '')[:10] for h in historial if h.get('fecha')))
    
    if rompimientos >= 1 and not usuario.get("logro_novato"):
        nuevos.append("novato")
        usuario["logro_novato"] = True
    if rompimientos >= 5 and not usuario.get("logro_curioso"):
        nuevos.append("curioso")
        usuario["logro_curioso"] = True
    if rompimientos >= 20 and not usuario.get("logro_adicto"):
        nuevos.append("adicto")
        usuario["logro_adicto"] = True
    if sabias >= 10 and not usuario.get("logro_sabio"):
        nuevos.append("sabio")
        usuario["logro_sabio"] = True
    if sarcasticas >= 10 and not usuario.get("logro_estoico"):
        nuevos.append("estoico")
        usuario["logro_estoico"] = True
    if recuerdos >= 5 and not usuario.get("logro_conversador"):
        nuevos.append("conversador")
        usuario["logro_conversador"] = True
    if fechas_unicas >= 7 and not usuario.get("logro_fiel"):
        nuevos.append("fiel")
        usuario["logro_fiel"] = True
    
    if nuevos:
        print("\n🏆 ¡LOGROS DESBLOQUEADOS! 🏆")
        for logro in nuevos:
            print(f"   ✓ {LOGROS[logro]}")
        input("\nPresiona Enter para continuar...")
        return True
    return False

def romper_galleta(usuario):
    # Preguntar contexto antes de romper
    print("\n🥠 la galleta te mira fijamente...")
    contexto = input("¿quieres contarle algo antes de romperla? (opcional, Enter para saltar): ").strip()
    
    if contexto:
        usuario.setdefault("recuerdos", []).append({
            "fecha": datetime.datetime.now().isoformat(),
            "mensaje": contexto,
            "temas": extraer_temas(contexto)
        })
        print("🥠 la galleta asiente lentamente y guarda tus palabras...")
    
    # Modo adivinanza (20% probabilidad)
    if random.random() < 0.2 and contexto:
        preguntas = [
            "¿estás pensando en alguien ahora mismo?",
            "¿algo te preocupa hoy?",
            "¿tomarás una decisión importante pronto?",
            "¿hay algo que no te atreves a decir?"
        ]
        pregunta = random.choice(preguntas)
        respuesta = input(f"\n🥠 {pregunta} (sí/no): ").strip().lower()
        
        if respuesta in ["sí", "si", "s", "sí"]:
            print("🥠 lo sabía. la galleta siempre sabe.")
            usuario["aciertos"] = usuario.get("aciertos", 0) + 1
        else:
            print("🥠 *ruido de galleta escéptica*")
    
    # Obtener frase
    frase, personalidad = obtener_frase(usuario)
    
    # Personalizar según recuerdos (30% probabilidad)
    if usuario.get("recuerdos") and random.random() < 0.3:
        recuerdo = random.choice(usuario["recuerdos"])
        if recuerdo.get("mensaje"):
            frase = f"recuerdo cuando dijiste '{recuerdo['mensaje'][:40]}...' → {frase.lower()}"
    
    entrada = {
        "fecha": datetime.datetime.now().isoformat(),
        "mensaje": frase,
        "personalidad": personalidad
    }
    
    usuario.setdefault("historial", []).append(entrada)
    usuario["rompimientos"] = usuario.get("rompimientos", 0) + 1
    
    # Limitar historial a últimas 50
    if len(usuario["historial"]) > 50:
        usuario["historial"] = usuario["historial"][-50:]
    
    print("\n" + "="*50)
    print(f"🥠 {frase}")
    print(f"🎭 personalidad: {personalidad}")
    print("="*50)
    
    # Verificar logros
    desbloquear_logros(usuario)

def ver_historial(usuario):
    print("\n📜 HISTORIAL DE LA GALLETA")
    print("="*50)
    
    historial = usuario.get("historial", [])
    
    if not historial:
        print("no has roto ninguna galleta. comportamiento sospechoso.")
        return
    
    for i, h in enumerate(historial[-10:], 1):  # Mostrar últimas 10
        fecha = h['fecha'][:16] if h.get('fecha') else 'fecha desconocida'
        print(f"{i}. {fecha} [{h.get('personalidad', '?')}]")
        print(f"   → {h.get('mensaje', '...')}\n")
    
    if len(historial) > 10:
        print(f"... y {len(historial)-10} más en el archivo.")

def mostrar_estadisticas(usuario):
    print("\n📊 ESTADÍSTICAS DE TU GALLA")
    print("="*50)
    print(f"🥠 Galletas rotas: {usuario.get('rompimientos', 0)}")
    print(f"🎯 Aciertos de la galleta: {usuario.get('aciertos', 0)}")
    print(f"💬 Recuerdos compartidos: {len(usuario.get('recuerdos', []))}")
    
    historial = usuario.get('historial', [])
    if historial:
        print(f"📅 Primera vez: {historial[0]['fecha'][:10]}")
        print(f"⏰ Última vez: {historial[-1]['fecha'][:10]}")
    
    # Distribución de personalidades
    if historial:
        personalidades = [h.get('personalidad', 'unknown') for h in historial]
        distro = Counter(personalidades)
        print("\n🎭 Distribución de personalidades:")
        for p, count in distro.most_common():
            barra = '█' * min(count, 20)
            print(f"   {p}: {barra} ({count})")
    
    # Racha actual (días seguidos)
    if len(historial) >= 2:
        fechas = []
        for h in historial:
            try:
                fechas.append(datetime.datetime.fromisoformat(h['fecha']).date())
            except:
                continue
        
        if fechas:
            fechas_unicas = sorted(set(fechas))
            racha = 1
            for i in range(len(fechas_unicas)-1, 0, -1):
                if (fechas_unicas[i] - fechas_unicas[i-1]).days <= 1:
                    racha += 1
                else:
                    break
            print(f"\n🔥 Racha actual: {racha} día(s) seguido(s)")
    
    # Logros conseguidos
    logros_conseguidos = [nombre for nombre in LOGROS.keys() if usuario.get(f"logro_{nombre}")]
    if logros_conseguidos:
        print(f"\n🏆 Logros conseguidos: {len(logros_conseguidos)}/{len(LOGROS)}")
        for logro in logros_conseguidos:
            print(f"   ✓ {LOGROS[logro]}")
    else:
        print("\n🏆 Aún no tienes logros. ¡Sigue rompiendo galletas!")

