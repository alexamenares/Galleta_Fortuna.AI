    print("\n" + "="*50)
    print("🥠  GALLETA INTELIGENTE  🥠".center(50))
    print("="*50)
    
    # Mostrar estadísticas rápidas
    print(f"👤 {nombre} | 🥠 rotas: {usuario.get('rompimientos', 0)}")
    print(f"🎭 personalidad actual: {obtener_personalidad(usuario)}")
    
    print("\n  1. 🔮 Romper galleta")
    print("  2. 📜 Ver historial")
    print("  3. 💬 Estado de la galleta")
    print("  4. 📊 Estadísticas detalladas")
    print("  5. 🧹 Resetear mi progreso")
    print("  6. 🚪 Salir")
    print("\n" + "-"*50)
    
    return input("  → ").strip()

def main():
    limpiar_pantalla()
    print("🥠 bienvenido a la galleta que recuerda cosas de ti")
    print("esto probablemente no es saludable emocionalmente, pero seguimos\n")
    
    data = cargar()
    nombre = pedir_nombre()
    
    if nombre not in data["usuarios"]:
        data["usuarios"][nombre] = {
            "historial": [],
            "rompimientos": 0,
            "recuerdos": []
        }
        print(f"\n🥠 ¡Hola {nombre}! La galleta te observa por primera vez.")
    else:
        print(f"\n🥠 {nombre}... otra vez tú. La galleta te reconoce.")
    
    usuario = data["usuarios"][nombre]
    guardar_con_backup(data)
    
    while True:
        op = menu(nombre, usuario)
        
        if op == "1":
            romper_galleta(usuario)
            guardar_con_backup(data)
            input("\nPresiona Enter para continuar...")
        
        elif op == "2":
            ver_historial(usuario)
            input("\nPresiona Enter para continuar...")
        
        elif op == "3":
            estado_galleta(usuario)
            input("\nPresiona Enter para continuar...")
        
        elif op == "4":
            mostrar_estadisticas(usuario)
            input("\nPresiona Enter para continuar...")
        
        elif op == "5":
            usuario = resetear_progreso(usuario, nombre, data)
            input("\nPresiona Enter para continuar...")
        
        elif op == "6":
            guardar_con_backup(data)
            print("\n🥠 la galleta se queda observando en silencio...")
            print("   sabe que volverás. siempre vuelves.")
            break
        
        else:
            print("🥠 opción inválida. incluso el destino está confundido.")
            input("Presiona Enter para continuar...")

if __name__ == "__main__":
    main()
