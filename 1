    print("\n⚠️ ¡CUIDADO! Esto borrará TODO tu progreso.")
    confirmacion = input("¿Estás seguro? Escribe 'SI' para confirmar: ").strip().upper()
    
    if confirmacion == "SI":
        data["usuarios"][nombre] = {
            "historial": [],
            "rompimientos": 0,
            "recuerdos": []
        }
        guardar_con_backup(data)
        print("🥠 La galleta ha olvidado todo. Empiezas de cero.")
        return data["usuarios"][nombre]
    else:
        print("🥠 Menos mal. La galleta suspira aliviada.")
